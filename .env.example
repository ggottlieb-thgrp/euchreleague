# --- Database (Vercel Postgres / Neon) ---
# Vercel injects POSTGRES_URL automatically when you attach a Postgres store.
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# --- Auth.js ---
# Generate with: npx auth secret   (or openssl rand -base64 32)
AUTH_SECRET=""
# Public base URL (set automatically on Vercel; needed locally)
AUTH_URL="https://thgeuchre.com"

# --- Email (Resend) ---
RESEND_API_KEY=""
# Send from the domain you own + verify in Resend (thgeuchre.com). This avoids
# needing THG IT to add DNS records to thgrp.com.
EMAIL_FROM="THG Euchre League <noreply@thgeuchre.com>"
# Replies go to your inbox even though mail is sent from the league domain.
EMAIL_REPLY_TO="ggottlieb@thgrp.com"

# --- Access control ---
# Only addresses on this domain may sign in.
ALLOWED_EMAIL_DOMAIN="thgrp.com"
# Comma-separated admin emails granted the admin role on first login.
ADMIN_EMAILS="ggottlieb@thgrp.com"

# --- Cron (Vercel) ---
# Vercel sends `Authorization: Bearer $CRON_SECRET` to cron routes.
CRON_SECRET=""

# --- App ---
# Office timezone used for all weekly scheduling logic.
LEAGUE_TIMEZONE="America/Indiana/Indianapolis"
